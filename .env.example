# ===========================================
# 示例配置文件
# ===========================================
# 将此文件复制到 .env 根据需要修改配置

# ===========================================
# 日志配置
# ===========================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# API文档配置
# ===========================================
API_DOCS_ENABLED=True

# ===========================================
# 服务配置
# ===========================================
HOST=0.0.0.0
PORT=8082
WORKERS=1

# ===========================================
# Agent 配置 (s01)
# ===========================================
# API密钥 (必填)
API_KEY=your-api-key-here
# 模型ID (默认: claude-sonnet-4-20250514)
MODEL_ID=claude-sonnet-4-20250514
# API基础URL (可选，用于自定义端点或代理)
API_BASE_URL=
# 最大token数 (默认: 8096)
MAX_TOKENS=8096

